---
// Pure-CSS device mockup that shows Research Buddy's "explain on select" in
// action: a passage with one line highlighted, and the AI explanation card.
// No image asset required. Decorative — labelled for screen readers.
interface Props {
  class?: string;
}
const { class: className = '' } = Astro.props;

// Faux paragraph lines (width %). The highlighted one is the "explained" line.
const lines = [82, 96, 73, 90, 68];
---

<div
  class:list={['relative w-[270px] select-none sm:w-[290px]', className]}
  role="img"
  aria-label="Research Buddy showing a highlighted line of a PDF with an AI explanation card beneath it."
>
  <!-- Device bezel -->
  <div class="rounded-[2.4rem] bg-ink p-2.5 shadow-2xl ring-1 ring-black/5">
    <!-- Screen -->
    <div class="relative overflow-hidden rounded-[1.9rem] bg-surface">
      <!-- Status / doc bar -->
      <div class="flex items-center justify-between border-b border-line px-5 pb-3 pt-4">
        <span class="h-1.5 w-16 rounded-full bg-line"></span>
        <span class="h-3 w-3 rounded-full border-2 border-line"></span>
      </div>

      <!-- Page content -->
      <div class="space-y-3 px-5 pb-44 pt-5" aria-hidden="true">
        <span class="block h-2.5 w-2/5 rounded-full bg-ink/70"></span>
        <div class="space-y-2.5 pt-1">
          {
            lines.map((w, i) => (
              <span
                class:list={[
                  'block h-2 rounded-full',
                  i === 2 ? 'bg-highlight' : 'bg-line',
                ]}
                style={`width:${w}%`}
              />
            ))
          }
        </div>
        <div class="space-y-2.5 pt-3">
          <span class="block h-2 w-[88%] rounded-full bg-line"></span>
          <span class="block h-2 w-[64%] rounded-full bg-line"></span>
        </div>
      </div>

      <!-- Explanation card floating over the page -->
      <div class="absolute inset-x-3 bottom-3 rounded-2xl border border-line bg-surface/95 p-4 shadow-lg backdrop-blur">
        <div class="flex items-center gap-2">
          <span class="flex h-5 w-5 items-center justify-center rounded-full bg-accent">
            <svg class="h-3 w-3 text-white" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M12 3l1.9 5.1L19 10l-5.1 1.9L12 17l-1.9-5.1L5 10l5.1-1.9L12 3z" fill="currentColor"/>
            </svg>
          </span>
          <span class="text-xs font-semibold tracking-wide text-ink">Explain this line</span>
        </div>
        <p class="mt-2 text-[13px] leading-snug text-ink-soft">
          “Entropy” here is the amount of disorder in the system — the reaction
          releases energy and raises it, so it proceeds on its own.
        </p>
      </div>
    </div>
  </div>
</div>
