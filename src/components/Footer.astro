---
import Brandmark from './Brandmark.astro';
import { SITE, NAV } from '../consts';

const year = new Date().getFullYear(); // stamped at build time
---

<footer class="mt-24 border-t border-line/70">
  <div class="shell flex flex-col gap-6 py-10 sm:flex-row sm:items-center sm:justify-between">
    <div class="flex items-center gap-2.5">
      <Brandmark class="h-6 w-6" />
      <span class="font-serif text-base font-medium tracking-tight text-ink">
        {SITE.name}
      </span>
    </div>

    <nav aria-label="Footer">
      <ul class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-muted">
        {
          NAV.map(({ href, label }) => (
            <li>
              <a href={href} class="transition-colors hover:text-ink">
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>

  <div class="shell pb-10">
    <p class="text-sm text-muted">
      © {year} {SITE.name}. Made for people who read closely.
    </p>
  </div>
</footer>
