---
// The three core gestures, mapped 1:1 to the app's interactions.
const cards = [
  {
    gesture: 'Long-press',
    title: 'Define a word',
    body: 'That term everyone in your field treats as obvious? Press and hold it — and get a definition in the context of what you’re reading, not a generic entry that sends you down three more words you don’t know.',
    icon: 'press',
  },
  {
    gesture: 'Swipe across',
    title: 'Explain a line',
    body: 'The sentence you’ve reread four times. Slide across it and Buddy says it back in plain language — the meaning, not a thesaurus.',
    icon: 'horizontal',
  },
  {
    gesture: 'Sweep down',
    title: 'Unpack a passage',
    body: 'A paragraph that’s all clauses and no mercy. Sweep down it for the gist before you commit to reading it closely.',
    icon: 'vertical',
  },
] as const;
---

<section class="shell py-16 sm:py-24">
  <header class="max-w-2xl">
    <p class="text-xs font-medium uppercase tracking-[0.14em] text-accent">How it works</p>
    <h2 class="mt-3 text-3xl font-medium tracking-tight sm:text-4xl">
      Three gestures. That’s the whole interface.
    </h2>
    <p class="mt-4 text-lg leading-relaxed text-ink-soft">
      No menus, no copy-paste, no leaving the app. You ask a question the way
      you’d point at it on paper.
    </p>
  </header>

  <div class="mt-12 grid gap-5 sm:grid-cols-3">
    {
      cards.map((c) => (
        <article class="rounded-2xl border border-line bg-surface p-6">
          <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-accent-soft text-accent">
            {c.icon === 'press' && (
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 11V6.5a1.5 1.5 0 0 1 3 0V13" />
                <path d="M15 12.5a1.5 1.5 0 0 1 3 0V16a4 4 0 0 1-4 4h-1.6a4 4 0 0 1-3.1-1.48l-2.5-3.1a1.5 1.5 0 0 1 2.2-2l1.5 1.4" />
                <circle cx="6" cy="6" r="2.4" opacity="0.45" />
              </svg>
            )}
            {c.icon === 'horizontal' && (
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14" />
                <path d="M8 9 5 12l3 3" />
                <path d="m16 9 3 3-3 3" />
              </svg>
            )}
            {c.icon === 'vertical' && (
              <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M12 5v14" />
                <path d="m9 8 3-3 3 3" />
                <path d="m9 16 3 3 3-3" />
              </svg>
            )}
          </span>
          <p class="mt-5 text-xs font-medium uppercase tracking-[0.12em] text-muted">{c.gesture}</p>
          <h3 class="mt-1 font-serif text-xl font-medium text-ink">{c.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-muted">{c.body}</p>
        </article>
      ))
    }
  </div>
</section>
