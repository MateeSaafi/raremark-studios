---
import BaseLayout from './BaseLayout.astro';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    lastUpdated?: string;
  };
}

const { frontmatter } = Astro.props;
const { title, description, lastUpdated } = frontmatter;
---

<BaseLayout title={title} description={description} type="article">
  <article class="mx-auto w-full max-w-2xl px-5 py-14 sm:px-6 sm:py-20">
    <header class="mb-10 border-b border-line pb-8">
      <h1 class="font-serif text-4xl font-medium tracking-tight sm:text-[2.75rem]">
        {title}
      </h1>
      {
        lastUpdated && (
          <p class="mt-4 text-sm text-muted">Last updated {lastUpdated}</p>
        )
      }
    </header>

    <div class="prose max-w-none prose-headings:font-medium prose-h2:mt-12 prose-h2:text-2xl prose-a:font-medium hover:prose-a:text-accent-strong">
      <slot />
    </div>
  </article>
</BaseLayout>
