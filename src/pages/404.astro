---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="That page doesn’t exist — let’s get you back to something that does.">
  <section class="shell flex min-h-[55vh] flex-col items-center justify-center py-24 text-center">
    <p class="font-serif text-6xl font-medium text-accent">404</p>
    <h1 class="mt-4 font-serif text-3xl font-medium tracking-tight sm:text-4xl">
      This page wandered off.
    </h1>
    <p class="mt-4 max-w-md text-lg leading-relaxed text-ink-soft">
      The link may be broken, or the page may have moved. Let’s get you back to
      something that exists.
    </p>
    <a href="/" class="btn-primary mt-8">Back to home</a>
  </section>
</BaseLayout>
