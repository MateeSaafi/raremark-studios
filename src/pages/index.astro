---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import FeaturedProduct from '../components/FeaturedProduct.astro';
import { RESEARCH_BUDDY_URL } from '../consts';

const principles = [
  {
    title: 'Earn the screen',
    body: 'Every element has to justify the attention it costs, or it doesn’t ship. We’d rather make one tool you trust than ten you tolerate.',
  },
  {
    title: 'Quiet by default',
    body: 'No feeds to fall into, no streaks to keep, no notifications begging you back. You come to it; it doesn’t come to you.',
  },
  {
    title: 'Your reading is yours',
    body: 'Your documents stay on your device. We send only what you choose to ask about, keep no more than we need, and never turn your reading into a product.',
  },
];
---

<BaseLayout title="Raremark Studios — calm, focused tools for people who read closely">
  <Hero />

  <!-- What we believe -->
  <section class="shell border-t border-line/70 py-16 sm:py-24">
    <div class="max-w-2xl">
      <p class="text-xs font-medium uppercase tracking-[0.14em] text-accent">What we believe</p>
      <h2 class="mt-3 text-3xl font-medium tracking-tight sm:text-4xl">
        Most software wants your attention. Ours wants to give it back.
      </h2>
      <div class="mt-6 space-y-6 font-serif text-xl leading-relaxed text-ink-soft">
        <p>
          Most apps are built to hold you. They nudge, badge, and interrupt,
          then call the hours you lost ‘engagement.’ We got tired of software
          that treats a quiet mind as a surface to interrupt — so we build the
          opposite: deliberate tools that do their one job, then step back out
          of the page.
        </p>
        <p>
          We read for a living, and we make tools the way we’d want them made —
          quietly, and only after we’ve felt the problem ourselves. Nothing here
          blinks for a second of you that wasn’t offered. If we wouldn’t keep it
          on our own phones, we don’t ship it.
        </p>
      </div>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-3">
      {
        principles.map((p) => (
          <div class="rounded-2xl border border-line bg-surface p-6">
            <h3 class="font-serif text-lg font-medium text-ink">{p.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{p.body}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- First from the studio: Research Buddy -->
  <FeaturedProduct />

  <!-- What's next -->
  <section class="shell border-t border-line/70 py-14 sm:py-16">
    <p class="mx-auto max-w-2xl text-center font-serif text-xl leading-relaxed text-muted sm:text-2xl">
      Research Buddy is the first of these. A few more tools are quietly taking
      shape, and we’ll show them when they’re ready — not before.
    </p>
  </section>

  <!-- Closing -->
  <section class="shell pb-4">
    <div class="rounded-3xl bg-accent-soft px-6 py-14 text-center ring-1 ring-accent/10 sm:px-12">
      <h2 class="mx-auto max-w-xl text-3xl font-medium tracking-tight sm:text-4xl">
        Read closely. We’ll stay out of the way.
      </h2>
      <p class="mx-auto mt-4 max-w-lg text-lg text-ink-soft">
        Research Buddy is the first thing we’ve made. Have a look, then tell us
        what it gets right and where it falls short — we read every note.
      </p>
      <div class="mt-8 flex justify-center">
        <a href={RESEARCH_BUDDY_URL} class="btn-primary">
          Visit Research Buddy
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M7 17 17 7" />
            <path d="M7 7h10v10" />
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
