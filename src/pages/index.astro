---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Gestures from '../components/Gestures.astro';
import PlayButton from '../components/PlayButton.astro';

// Placeholder slots — drop real PNGs into public/screenshots/ and swap these.
const shots = [
  { label: 'Reading view' },
  { label: 'Explain a line' },
  { label: 'Word definition' },
];
---

<BaseLayout
  title="Research Buddy — Understand any PDF"
  description="Research Buddy is a minimalist PDF reader for Android with AI explanations built into the page. Long-press to define, swipe to explain — without losing your place."
>
  <Hero />

  <!-- What it is -->
  <section class="shell border-t border-line/70 py-16 sm:py-24">
    <div class="max-w-2xl">
      <p class="text-xs font-medium uppercase tracking-[0.14em] text-accent">What it is</p>
      <div class="mt-5 space-y-6 font-serif text-xl leading-relaxed text-ink-soft">
        <p>
          Research Buddy is a PDF reader built for <em class="text-ink not-italic">understanding</em>,
          not just viewing. It opens your files fast, gets out of the way, and
          keeps a capable AI reader one gesture away — so dense papers,
          textbooks, and contracts stop being a wall of text.
        </p>
        <p>
          It’s deliberately small. No sign-up, no feed, no settings maze. Your
          documents stay on your device; only the specific text you choose to
          explain is sent to our service to generate an answer. That’s the
          whole deal.
        </p>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <Gestures />

  <!-- A closer look (screenshot placeholders) -->
  <section class="shell border-t border-line/70 py-16 sm:py-24">
    <header class="max-w-2xl">
      <p class="text-xs font-medium uppercase tracking-[0.14em] text-accent">A closer look</p>
      <h2 class="mt-3 text-3xl font-medium tracking-tight sm:text-4xl">See it on the page.</h2>
      <p class="mt-4 text-lg leading-relaxed text-ink-soft">
        Real screenshots land here closer to launch. The shape is the point:
        your document, full-bleed, with help a gesture away.
      </p>
    </header>

    <!-- Horizontal, no-JS scroll strip. Replace frames with real screenshots. -->
    <div class="mt-10 -mx-5 flex snap-x gap-4 overflow-x-auto px-5 pb-4 sm:mx-0 sm:px-0">
      {
        shots.map((s) => (
          <div class="snap-start">
            <div class="flex aspect-[9/19] w-[190px] shrink-0 flex-col items-center justify-center gap-3 rounded-[1.8rem] border-2 border-dashed border-line bg-surface text-muted">
              <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
                <rect x="3" y="3" width="18" height="18" rx="3" />
                <circle cx="8.5" cy="8.5" r="1.5" />
                <path d="m21 15-5-5L5 21" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="text-xs font-medium">{s.label}</span>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="shell pb-4">
    <div class="rounded-3xl bg-accent-soft px-6 py-14 text-center ring-1 ring-accent/10 sm:px-12">
      <h2 class="mx-auto max-w-xl text-3xl font-medium tracking-tight sm:text-4xl">
        Read your next PDF with a buddy.
      </h2>
      <p class="mx-auto mt-4 max-w-md text-lg text-ink-soft">
        No account. No tracking. No clutter — just you, the page, and answers
        when you want them.
      </p>
      <div class="mt-8 flex justify-center">
        <PlayButton caption={false} />
      </div>
    </div>
  </section>
</BaseLayout>
